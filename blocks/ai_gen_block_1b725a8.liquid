{% doc %}
  @prompt
    craft me a dynamic breadcrumb section 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-breadcrumb-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-breadcrumb-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-breadcrumb-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-breadcrumb-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-breadcrumb-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ai-breadcrumb-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: {% if block.settings.underline_on_hover %}underline{% else %}none{% endif %};
  }

  .ai-breadcrumb-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    user-select: none;
  }

  .ai-breadcrumb-current-{{ ai_gen_id }} {
    color: {{ block.settings.current_page_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-breadcrumb-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 0 {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-breadcrumb-list-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<breadcrumb-navigation-{{ ai_gen_id }} class="ai-breadcrumb-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-breadcrumb-container-{{ ai_gen_id }}">
    <nav aria-label="Breadcrumb">
      <ol class="ai-breadcrumb-list-{{ ai_gen_id }}">
        <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <a href="/" class="ai-breadcrumb-link-{{ ai_gen_id }}">
            {% if block.settings.show_home_icon %}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 6L8 1L14 6V13C14 13.2652 13.8946 13.5196 13.7071 13.7071C13.5196 13.8946 13.2652 14 13 14H3C2.73478 14 2.48043 13.8946 2.29289 13.7071C2.10536 13.5196 2 13.2652 2 13V6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M6 14V8H10V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {% else %}
              {{ block.settings.home_text }}
            {% endif %}
          </a>
        </li>

        {% if template.name == 'collection' and collection %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">{{ collection.title }}</span>
          </li>

        {% elsif template.name == 'product' and product %}
          {% if collection %}
            <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
              <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
            </li>
            <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
              <a href="{{ collection.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ collection.title }}</a>
            </li>
          {% endif %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">{{ product.title }}</span>
          </li>

        {% elsif template.name == 'page' and page %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">{{ page.title }}</span>
          </li>

        {% elsif template.name == 'blog' and blog %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">{{ blog.title }}</span>
          </li>

        {% elsif template.name == 'article' and article %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <a href="{{ blog.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ blog.title }}</a>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">{{ article.title }}</span>
          </li>

        {% elsif template.name == 'search' %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">Search results</span>
          </li>

        {% elsif template.name == 'cart' %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">Cart</span>
          </li>

        {% elsif template.name == 'list-collections' %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">Collections</span>
          </li>

        {% elsif template.name == 'account' or template.name == 'login' or template.name == 'register' %}
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          </li>
          <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <span class="ai-breadcrumb-current-{{ ai_gen_id }}">Account</span>
          </li>
        {% endif %}
      </ol>
    </nav>
  </div>
</breadcrumb-navigation-{{ ai_gen_id }}>

<script>
  (function() {
    class BreadcrumbNavigation{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.addStructuredData();
      }

      addStructuredData() {
        const breadcrumbList = this.querySelector('.ai-breadcrumb-list-{{ ai_gen_id }}');
        if (!breadcrumbList) return;

        const items = [];
        const links = breadcrumbList.querySelectorAll('.ai-breadcrumb-link-{{ ai_gen_id }}');
        const currentPage = breadcrumbList.querySelector('.ai-breadcrumb-current-{{ ai_gen_id }}');

        links.forEach((link, index) => {
          items.push({
            '@type': 'ListItem',
            'position': index + 1,
            'name': link.textContent.trim(),
            'item': link.href
          });
        });

        if (currentPage) {
          items.push({
            '@type': 'ListItem',
            'position': items.length + 1,
            'name': currentPage.textContent.trim()
          });
        }

        const structuredData = {
          '@context': 'https://schema.org',
          '@type': 'BreadcrumbList',
          'itemListElement': items
        };

        const script = document.createElement('script');
        script.type = 'application/ld+json';
        script.textContent = JSON.stringify(structuredData);
        this.appendChild(script);
      }
    }

    customElements.define('breadcrumb-navigation-{{ ai_gen_id }}', BreadcrumbNavigation{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Breadcrumb navigation",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Home link"
    },
    {
      "type": "checkbox",
      "id": "show_home_icon",
      "label": "Show home icon",
      "default": true
    },
    {
      "type": "text",
      "id": "home_text",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator character",
      "default": "/"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "underline_on_hover",
      "label": "Underline links on hover",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2b2b2b"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#c9a24d"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#b18a3d"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator",
      "default": "#e6e2d8"
    },
    {
      "type": "color",
      "id": "current_page_color",
      "label": "Current page",
      "default": "#0f0f0f"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Breadcrumb navigation"
    }
  ]
}
{% endschema %}
