{% doc %}
  @prompt
    Create a Shopify section called “Testimonials Slider”.
    
    The section should display testimonials in an auto-rotating slider.
    
    Each testimonial block must include:
    
    Customer image (image picker)
    
    Customer name (text)
    
    Star rating (1–5, displayed as filled stars)
    
    Testimonial text (textarea)
    
    Slider behavior:
    
    Auto-rotate every 4–5 seconds
    
    Smooth fade or slide transition
    
    Pause on hover (desktop)
    
    Swipe support on mobile
    
    Design requirements:
    
    Clean, premium, modern layout suitable for a jewellery brand
    
    Rounded customer images
    
    Gold-colored stars (using CSS, not images)
    
    Center-aligned content
    
    Responsive and mobile-friendly
    
    Section settings:
    
    Section heading text
    
    Background color selector
    
    Autoplay on/off toggle
    
    Use vanilla JavaScript only (no external libraries).
    Use Shopify Liquid best practices and schema blocks.
    Ensure the section works without any theme dependencies., can you make the height a little compact 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 30px;
    font-size: 32px;
    color: {{ block.settings.heading_color }};
  }

  .ai-testimonials-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    min-height: 300px;
  }

  .ai-testimonial-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
    text-align: center;
    padding: 10px;
  }

  .ai-testimonial-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    position: relative;
  }

  .ai-testimonial-image-wrapper-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid {{ block.settings.image_border_color }};
  }

  .ai-testimonial-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 16px;
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    position: relative;
  }

  .ai-testimonial-star-{{ ai_gen_id }}::before {
    content: '★';
    position: absolute;
    top: 0;
    left: 0;
    font-size: 18px;
    color: {{ block.settings.star_color }};
  }

  .ai-testimonial-star-{{ ai_gen_id }}.empty::before {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-testimonial-text-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-style: italic;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: 15px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0;
  }

  .ai-testimonials-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
  }

  .ai-testimonial-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.4;
  }

  .ai-testimonial-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-testimonials-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 24px;
  }

  .ai-testimonial-nav-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: {{ block.settings.nav_button_icon_color }};
  }

  .ai-testimonial-nav-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
    transform: scale(1.1);
  }

  .ai-testimonial-nav-btn-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-slider-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 24px;
    }

    .ai-testimonial-text-{{ ai_gen_id }} {
      font-size: 15px;
    }

    .ai-testimonials-slider-wrapper-{{ ai_gen_id }} {
      min-height: 280px;
    }

    .ai-testimonial-image-wrapper-{{ ai_gen_id }} {
      width: 70px;
      height: 70px;
      margin-bottom: 16px;
    }
  }
{% endstyle %}

<testimonials-slider-{{ ai_gen_id }}
  class="ai-testimonials-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-interval="{{ block.settings.autoplay_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-testimonials-slider-wrapper-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'customer_image_' | append: i
          assign name_key = 'customer_name_' | append: i
          assign rating_key = 'star_rating_' | append: i
          assign text_key = 'testimonial_text_' | append: i

          assign customer_image = block.settings[image_key]
          assign customer_name = block.settings[name_key]
          assign star_rating = block.settings[rating_key]
          assign testimonial_text = block.settings[text_key]
        %}

        {% if customer_name != blank or testimonial_text != blank %}
          <div class="ai-testimonial-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
            <div class="ai-testimonial-image-wrapper-{{ ai_gen_id }}">
              {% if customer_image %}
                <img
                  src="{{ customer_image | image_url: width: 200 }}"
                  alt="{{ customer_name | escape }}"
                  class="ai-testimonial-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-testimonial-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-testimonial-stars-{{ ai_gen_id }}">
              {% for j in (1..5) %}
                {% if j <= star_rating %}
                  <span class="ai-testimonial-star-{{ ai_gen_id }}"></span>
                {% else %}
                  <span class="ai-testimonial-star-{{ ai_gen_id }} empty"></span>
                {% endif %}
              {% endfor %}
            </div>

            {% if testimonial_text != blank %}
              <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ testimonial_text }}</p>
            {% endif %}

            {% if customer_name != blank %}
              <p class="ai-testimonial-name-{{ ai_gen_id }}">{{ customer_name }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-testimonials-nav-{{ ai_gen_id }}">
      <button
        class="ai-testimonial-nav-btn-{{ ai_gen_id }} ai-testimonial-prev-{{ ai_gen_id }}"
        aria-label="Previous testimonial"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-testimonial-nav-btn-{{ ai_gen_id }} ai-testimonial-next-{{ ai_gen_id }}"
        aria-label="Next testimonial"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <div class="ai-testimonials-dots-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign name_key = 'customer_name_' | append: i
          assign text_key = 'testimonial_text_' | append: i
          assign customer_name = block.settings[name_key]
          assign testimonial_text = block.settings[text_key]
        %}
        {% if customer_name != blank or testimonial_text != blank %}
          <button
            class="ai-testimonial-dot-{{ ai_gen_id }}"
            data-slide="{{ forloop.index0 }}"
            aria-label="Go to testimonial {{ forloop.index }}"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonials-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.isPaused = false;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-testimonial-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-testimonial-dot-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-testimonial-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-testimonial-next-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.interval = parseInt(this.dataset.interval) * 1000;

        if (this.slides.length === 0) return;

        this.showSlide(0);
        this.setupEventListeners();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => {
            this.previousSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => {
            this.nextSlide();
            this.resetAutoplay();
          });
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.showSlide(index);
            this.resetAutoplay();
          });
        });

        this.addEventListener('mouseenter', () => {
          this.isPaused = true;
        });

        this.addEventListener('mouseleave', () => {
          this.isPaused = false;
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
          this.resetAutoplay();
        }
      }

      showSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.currentSlide = index;
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.showSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.showSlide(prevIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          if (!this.isPaused) {
            this.nextSlide();
          }
        }, this.interval);
      }

      resetAutoplay() {
        if (this.autoplay && this.slides.length > 1) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('testimonials-slider-{{ ai_gen_id }}', TestimonialsSlider{{ ai_gen_id }});
  })();
</script>

